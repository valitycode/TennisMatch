      const selected = notes.find(n => n.id === selectedNoteId) || notes[0] || null;
      if (selected && !selectedNoteId) selectedNoteId = selected.id;
      elements.screens.notes.innerHTML = `
        <div class="stack" style="margin-top:20px;">
          <section class="card">
            <div class="card-inner">
              <div class="section-header"><div><h2>Mes notes</h2><p class="section-subtle">Liste des titres à gauche, note complète à droite, comme Apple Notes.</p></div><button class="primary-btn" id="addNoteBtn" style="width:auto;background:#0f172a;color:white;">+ Nouvelle note</button></div>
              <div class="notes-workspace">
                <div class="list-panel">
                  ${notes.length ? notes.map(note => `<article class="list-item ${selected?.id === note.id ? 'active' : ''}" data-open-note="${note.id}"><div class="section-subtle">${escapeHtml(note.course || 'Sans matière')}</div><h3 style="margin-top:4px;">${escapeHtml(note.title)}</h3><p>${new Date(note.updatedAt).toLocaleDateString('fr-FR')}</p></article>`).join('') : `<article class="list-item"><h3>Aucune note</h3><p>Crée ta première note.</p></article>`}
                </div>
                <div class="editor-pane">
                  ${selected ? `
                    <div class="editor-top">
                      <input id="noteTitleEditor" value="${escapeHtml(selected.title)}" placeholder="Titre" />
                      <input id="noteCourseEditor" value="${escapeHtml(selected.course || '')}" placeholder="Matière" />
                    </div>
                    <textarea id="noteContentEditor" placeholder="Écris ton cours ici...">${escapeHtml(selected.content)}</textarea>
                    <div style="display:flex;gap:10px;flex-wrap:wrap;">
                      <button class="primary-btn" id="saveCurrentNoteBtn" style="width:auto;background:#0f172a;color:white;">Enregistrer</button>
                      <button class="ghost-btn" id="deleteCurrentNoteBtn" style="padding:12px 16px;border-radius:18px;background:#fee2e2;color:#991b1b;">Supprimer</button>
                    </div>
                  ` : `<article class="note-card"><h3>Aucune note sélectionnée</h3><p>Choisis un titre ou crée une nouvelle note.</p></article>`}
                </div>
              </div>
            </div>
          </section>
        </div>
      `;
    }

