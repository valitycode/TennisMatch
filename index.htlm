            <div class="card-inner">
              <div class="section-header"><h2>Mode Focus</h2><div class="section-subtle" style="color:rgba(255,255,255,0.64)">${state.focusSessions} session(s) terminée(s)</div></div>
              <div class="focus-box">
                <div class="section-subtle" style="color:rgba(255,255,255,0.64)">Session active recommandée</div>
                <div class="focus-time">${formatTimer(state.focusRemaining)}</div>
                <div class="focus-actions">${[25,45,60].map(v => `<button class="small-btn ${state.focusMinutes === v ? 'active' : ''}" data-focus="${v}">${v} min</button>`).join('')}</div>
                <button id="startFocusBtn2" class="focus-btn">${state.focusRunning ? 'Pause' : 'Lancer la session'}</button>
                <button id="resetFocusBtn2" class="ghost-btn" style="margin-top:10px;padding:14px 16px;border-radius:18px;width:100%;">Réinitialiser</button>
              </div>
            </div>
          </section>
        </div>
      `;
    }

    function renderRessources() {
      elements.screens.ressources.innerHTML = `<div class="stack" style="margin-top:20px;"><div class="card"><div class="card-inner"><div class="section-header"><h2>Ressources</h2></div><p class="section-subtle">Zone conservée comme avant.</p></div></div></div>`;
    }

    function renderStats() {
      const doneTasks = state.tasks.filter(t => t.done).length;
      elements.screens.stats.innerHTML = `
        <div class="stack" style="margin-top:20px;">
          <section class="stats">
            <article class="card stat-card"><div class="card-inner"><div class="title">Notes</div><div class="value">${state.notes.length}</div><div class="section-subtle">Toutes matières</div></div></article>
            <article class="card stat-card"><div class="card-inner"><div class="title">Pronote</div><div class="value">${state.pronoteEvents.length}</div><div class="section-subtle">Cours importés</div></div></article>
            <article class="card stat-card"><div class="card-inner"><div class="title">Tâches faites</div><div class="value">${doneTasks}</div><div class="section-subtle">Bon rythme</div></div></article>
          </section>
        </div>
      `;
    }

    function renderPronote() {
      elements.screens.pronote.innerHTML = `
        <div class="main-grid" style="margin-top:20px;">
          <div class="stack">
            <section class="card">
              <div class="card-inner">
                <div class="section-header"><h2>Connexion Pronote</h2><div class="badge ${state.pronoteEvents.length ? 'status-good' : 'status-off'}">${state.pronoteEvents.length ? 'Synchronisé' : 'Non synchronisé'}</div></div>
                <p class="section-subtle">Le fichier .ics local reste le plus fiable.</p>
                <div style="display:grid; gap:12px; margin-top:18px;">
                  <div style="display:flex; gap:12px; flex-wrap:wrap;">
                    <label class="primary-btn" for="icsFileInput" style="width:auto;background:#0f172a;color:white;">Importer un fichier .ics</label>
                    <input id="icsFileInput" type="file" accept=".ics,text/calendar" class="hidden" />
                    <div class="badge" style="background:#e2e8f0;color:#334155;">${escapeHtml(state.pronoteSource || 'Aucun fichier')}</div>
                  </div>
                  <input id="pronoteIcalInput" class="search" type="text" placeholder="Colle ici un lien iCal" value="${escapeHtml(state.pronoteUrl || '')}" style="min-width:100%;" />
                  <div style="display:flex; gap:12px; flex-wrap:wrap;">
                    <button id="connectPronoteBtn" class="primary-btn" style="width:auto; background:#0f172a; color:white;">Lire l’URL</button>
                    <button id="demoPronoteBtn" class="primary-btn" style="width:auto;">Charger une démo</button>
                    <button id="disconnectPronoteBtn" class="ghost-btn" style="padding:12px 16px; border-radius:18px;">Réinitialiser</button>
                  </div>
                </div>
              </div>
            </section>

            <section class="card">
              <div class="card-inner">
                <div class="section-header"><h2>Calendrier des cours</h2><div class="section-subtle">Semaine actuelle</div></div>
                <div class="schedule-list">${state.pronoteEvents.length ? state.pronoteEvents.map(event => scheduleRow({ time: event.displayTime, subject: event.subject, meta: event.meta })).join('') : `<article class="note-card"><h3>Aucun cours chargé</h3><p>Importe un vrai calendrier pour remplir l’app.</p></article>`}</div>
              </div>
            </section>
          </div>

          <div class="stack">
            <section class="card">
              <div class="card-inner">
                <div class="section-header"><h2>État de la synchro</h2></div>
                <div class="note-list">
                  <article class="note-card"><div class="section-subtle">Source</div><h3>${escapeHtml(state.pronoteSource || 'Aucune source connectée')}</h3></article>
                  <article class="note-card"><div class="section-subtle">Dernière mise à jour</div><h3>${state.pronoteEvents.length ? new Date().toLocaleString('fr-FR') : 'Jamais'}</h3></article>
                  <article class="note-card"><div class="section-subtle">Cours importés</div><h3>${state.pronoteEvents.length} cours</h3></article>
                </div>
              </div>
            </section>
          </div>
        </div>
      `;
    }

    function exportDataJson() {
      const blob = new Blob([JSON.stringify(state, null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'eduflow-data.json';
      a.click();
      URL.revokeObjectURL(url);
    }

    async function importDataJson(event) {
      const file = event.target.files?.[0];
      if (!file) return;
      try {
        const parsed = JSON.parse(await file.text());
        const defaults = defaultState();
        Object.keys(state).forEach(key => delete state[key]);
        Object.assign(state, { ...defaults, ...parsed });
        selectedNoteId = state.notes[0]?.id || null;
        saveState();
        renderAll();
      } catch {
        alert('Fichier JSON invalide.');
      }
    }

    function downloadCurrentHtml() {
      const html = '<!DOCTYPE html>\n' + document.documentElement.outerHTML;
      const blob = new Blob([html], { type: 'text/html' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'eduflow-app.html';
      a.click();
      URL.revokeObjectURL(url);
    }

    function resetAllData() {
      if (!confirm('Supprimer toutes les données locales ?')) return;
      stopFocusTimer();
      const defaults = defaultState();
      Object.keys(state).forEach(key => delete state[key]);
      Object.assign(state, defaults);
      selectedNoteId = state.notes[0]?.id || null;
      saveState();
      renderAll();
    }

    function renderParametres() {
      elements.screens.parametres.innerHTML = `
        <div class="stack" style="margin-top:20px; max-width:900px;">
          <div class="card">
            <div class="card-inner">
              <div class="section-header"><h2>Paramètres</h2></div>
              <div class="switch-row">
                <div>
                  <div style="font-weight:700; font-size:18px;">Mode sombre</div>
                  <div class="section-subtle" style="margin-top:6px;">Active un thème sombre inspiré d’Apple pour le travail du soir.</div>
                </div>
                <button id="themeToggle" class="theme-switch ${state.dark ? 'active' : ''}" aria-label="Activer le mode sombre"></button>
              </div>
            </div>
          </div>

          <div class="card">
            <div class="card-inner">
              <div class="section-header"><h2>Partage</h2></div>
              <p class="section-subtle">Exporte tes données, importe une sauvegarde ou télécharge l’app HTML pour la partager.</p>
              <div style="display:flex;gap:12px;flex-wrap:wrap; margin-top:14px;">
                <button class="primary-btn" id="exportJsonBtn" style="width:auto;background:#0f172a;color:white;">Exporter les données</button>
                <label class="primary-btn" for="importJsonInput" style="width:auto;background:#0f172a;color:white;">Importer une sauvegarde</label>
                <input id="importJsonInput" type="file" accept="application/json" class="hidden" />
                <button class="ghost-btn" id="downloadHtmlBtn" style="padding:12px 16px;border-radius:18px;">Télécharger le HTML</button>
              </div>
            </div>
          </div>

          <div class="card">
            <div class="card-inner">
              <div class="section-header"><h2>Réinitialisation</h2></div>
              <p class="section-subtle">Supprime toutes les données locales enregistrées sur cet appareil.</p>
              <button class="ghost-btn" id="resetAllBtn" style="padding:12px 16px;border-radius:18px;background:#fee2e2;color:#991b1b; margin-top:14px;">Tout réinitialiser</button>
            </div>
          </div>
        </div>
      `;
    }

    function renderAll() {
      applyTheme();
      elements.topDate.textContent = formatLongDate();
      elements.searchInput.value = state.search;
      elements.assistantText.textContent = `${state.notes.length} notes, ${state.tasks.filter(t => !t.done).length} tâches à faire, ${state.pronoteEvents.length} cours importés.`;
      renderNav();
      Object.entries(elements.screens).forEach(([key, node]) => node.classList.toggle('hidden', key !== state.activeTab));
      renderAccueil();
      renderCours();
      renderNotes();
      renderTaches();
      renderFocus();
      renderRessources();
      renderStats();
      renderPronote();
      renderParametres();
      bindDynamicEvents();
    }

    function bindDynamicEvents() {
      document.getElementById('goCoursesBtn')?.addEventListener('click', () => { state.activeTab = 'cours'; saveState(); renderAll(); });
      document.getElementById('addCourseBtn')?.addEventListener('click', () => openCourseModal());
      document.getElementById('addTaskBtn')?.addEventListener('click', () => openTaskModal());
      document.getElementById('addTaskQuickBtn')?.addEventListener('click', () => openTaskModal());
      document.getElementById('addNoteBtn')?.addEventListener('click', () => openNoteModal());
      document.getElementById('addNoteQuickBtn')?.addEventListener('click', () => openNoteModal());

      document.querySelectorAll('[data-quick]').forEach(card => card.addEventListener('click', () => {
        const action = card.dataset.quick;
        if (action === 'new-note') openNoteModal();
        if (action === 'new-course') openCourseModal();
        if (action === 'new-task') openTaskModal();
        if (action === 'pronote') { state.activeTab = 'pronote'; saveState(); renderAll(); }
      }));

      document.querySelectorAll('[data-toggle-task]').forEach(card => card.addEventListener('click', () => {
        const task = state.tasks.find(t => t.id === card.dataset.toggleTask);
        if (!task) return;
        task.done = !task.done;
        saveState();
        renderAll();
      }));

      document.querySelectorAll('[data-edit-task]').forEach(btn => btn.addEventListener('click', e => { e.stopPropagation(); openTaskModal(btn.dataset.editTask); }));
      document.querySelectorAll('[data-delete-task]').forEach(btn => btn.addEventListener('click', e => { e.stopPropagation(); state.tasks = state.tasks.filter(task => task.id !== btn.dataset.deleteTask); saveState(); renderAll(); }));
      document.querySelectorAll('[data-edit-course]').forEach(btn => btn.addEventListener('click', () => openCourseModal(btn.dataset.editCourse)));
      document.querySelectorAll('[data-delete-course]').forEach(btn => btn.addEventListener('click', () => { state.courses = state.courses.filter(course => course.id !== btn.dataset.deleteCourse); saveState(); renderAll(); }));
      document.querySelectorAll('[data-open-note]').forEach(btn => btn.addEventListener('click', () => { selectedNoteId = btn.dataset.openNote; renderAll(); }));

      document.getElementById('saveCurrentNoteBtn')?.addEventListener('click', saveCurrentOpenedNote);
      document.getElementById('deleteCurrentNoteBtn')?.addEventListener('click', () => {
        state.notes = state.notes.filter(note => note.id !== selectedNoteId);
        selectedNoteId = state.notes[0]?.id || null;
        saveState();
        renderAll();
      });

      document.querySelectorAll('[data-focus]').forEach(btn => btn.addEventListener('click', () => {
        state.focusMinutes = Number(btn.dataset.focus);
        if (!state.focusRunning) state.focusRemaining = state.focusMinutes * 60;
        saveState();
        renderAll();
      }));

      document.getElementById('startFocusBtn')?.addEventListener('click', toggleFocus);
      document.getElementById('startFocusBtn2')?.addEventListener('click', toggleFocus);
      document.getElementById('resetFocusBtn')?.addEventListener('click', resetFocus);
      document.getElementById('resetFocusBtn2')?.addEventListener('click', resetFocus);

      document.getElementById('themeToggle')?.addEventListener('click', () => {
        state.dark = !state.dark;
        saveState();
        renderAll();
      });

      document.getElementById('exportJsonBtn')?.addEventListener('click', exportDataJson);
      document.getElementById('importJsonInput')?.addEventListener('change', importDataJson);
      document.getElementById('downloadHtmlBtn')?.addEventListener('click', downloadCurrentHtml);
      document.getElementById('resetAllBtn')?.addEventListener('click', resetAllData);

      document.getElementById('icsFileInput')?.addEventListener('change', importICSFile);
      document.getElementById('connectPronoteBtn')?.addEventListener('click', importICSUrl);
      document.getElementById('demoPronoteBtn')?.addEventListener('click', loadPronoteDemo);
      document.getElementById('disconnectPronoteBtn')?.addEventListener('click', () => {
        state.pronoteUrl = '';
        state.pronoteSource = '';
        state.pronoteEvents = [];
        saveState();
        renderAll();
      });
    }

    function openCourseModal(id = null) {
      const course = id ? state.courses.find(c => c.id === id) : null;
      openModal(course ? 'Modifier le cours' : 'Ajouter un cours', `
        <input id="courseNameInput" placeholder="Nom du cours" value="${escapeHtml(course?.name || '')}" />
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;"><input id="courseTeacherInput" placeholder="Professeur" value="${escapeHtml(course?.teacher || '')}" /><input id="courseRoomInput" placeholder="Salle" value="${escapeHtml(course?.room || '')}" /></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;"><input id="courseNextInput" placeholder="Prochain créneau (ex: 08:30)" value="${escapeHtml(course?.next || '')}" /><input id="courseProgressInput" type="number" min="0" max="100" placeholder="Progression manuelle" value="${Number(course?.progress || 0)}" /></div>
        <select id="courseGradientInput">${gradients.map(value => `<option value="${value}" ${course?.gradient === value ? 'selected' : ''}>Couleur</option>`).join('')}</select>
        <button class="primary-btn" id="saveCourseBtn" style="background:#0f172a;color:white;">Enregistrer</button>
      `);
      document.getElementById('saveCourseBtn').addEventListener('click', () => {
        const payload = {
          id: course?.id || uid(),
          name: document.getElementById('courseNameInput').value.trim(),
          teacher: document.getElementById('courseTeacherInput').value.trim(),
          room: document.getElementById('courseRoomInput').value.trim(),
          next: document.getElementById('courseNextInput').value.trim(),
          progress: Math.max(0, Math.min(100, Number(document.getElementById('courseProgressInput').value || 0))),
          gradient: document.getElementById('courseGradientInput').value
        };
        if (!payload.name) return;
        if (course) state.courses = state.courses.map(c => c.id === course.id ? payload : c);
        else state.courses.unshift(payload);
        saveState();
        closeModal();
        renderAll();
      });
    }

    function openTaskModal(id = null) {
      const task = id ? state.tasks.find(t => t.id === id) : null;
      openModal(task ? 'Modifier la tâche' : 'Ajouter une tâche', `
        <input id="taskTitleInput" placeholder="Titre" value="${escapeHtml(task?.title || '')}" />
        <input id="taskDueInput" placeholder="Échéance" value="${escapeHtml(task?.due || '')}" />
        <button class="primary-btn" id="saveTaskBtn" style="background:#0f172a;color:white;">Enregistrer</button>
      `);
      document.getElementById('saveTaskBtn').addEventListener('click', () => {
        const payload = {
          id: task?.id || uid(),
          title: document.getElementById('taskTitleInput').value.trim(),
          due: document.getElementById('taskDueInput').value.trim(),
          done: task?.done || false
        };
        if (!payload.title) return;
        if (task) state.tasks = state.tasks.map(t => t.id === task.id ? payload : t);
        else state.tasks.unshift(payload);
        saveState();
        closeModal();
        renderAll();
      });
    }

    function openNoteModal() {
      openModal('Nouvelle note', `
        <input id="newNoteTitle" placeholder="Titre" />
        <input id="newNoteCourse" placeholder="Matière" />
        <textarea id="newNoteContent" placeholder="Écris ton cours ici..."></textarea>
        <button class="primary-btn" id="saveNewNoteBtn" style="background:#0f172a;color:white;">Créer la note</button>
      `);
      document.getElementById('saveNewNoteBtn').addEventListener('click', () => {
        const note = {
          id: uid(),
          title: document.getElementById('newNoteTitle').value.trim(),
          course: document.getElementById('newNoteCourse').value.trim(),
          content: document.getElementById('newNoteContent').value.trim(),
          updatedAt: Date.now()
        };
        if (!note.title) return;
        state.notes.unshift(note);
        selectedNoteId = note.id;
        saveState();
        closeModal();
        state.activeTab = 'notes';
        renderAll();
      });
    }

    function saveCurrentOpenedNote() {
      const note = state.notes.find(n => n.id === selectedNoteId);
      if (!note) return;
      note.title = document.getElementById('noteTitleEditor').value.trim() || 'Sans titre';
      note.course = document.getElementById('noteCourseEditor').value.trim();
      note.content = document.getElementById('noteContentEditor').value;
      note.updatedAt = Date.now();
      saveState();
      renderAll();
    }

    function formatTimer(totalSeconds) {
      const mins = String(Math.floor(totalSeconds / 60)).padStart(2, '0');
      const secs = String(totalSeconds % 60).padStart(2, '0');
      return `${mins}:${secs}`;
    }

    function toggleFocus() {
      state.focusRunning = !state.focusRunning;
      if (state.focusRunning) startFocusTimer();
      else stopFocusTimer();
      saveState();
      renderAll();
    }

    function resetFocus() {
      stopFocusTimer();
      state.focusRunning = false;
      state.focusRemaining = state.focusMinutes * 60;
      saveState();
      renderAll();
    }

    function startFocusTimer() {
      stopFocusTimer();
      focusInterval = setInterval(() => {
        if (!state.focusRunning) return;
        if (state.focusRemaining <= 1) {
          state.focusRemaining = state.focusMinutes * 60;
          state.focusRunning = false;
          state.focusSessions += 1;
          stopFocusTimer();
          saveState();
          renderAll();
          alert('Session focus terminée.');
          return;
        }
        state.focusRemaining -= 1;
        saveState();
        document.querySelectorAll('#focusTime').forEach(node => node.textContent = formatTimer(state.focusRemaining));
      }, 1000);
    }

    function stopFocusTimer() {
      if (focusInterval) clearInterval(focusInterval);
      focusInterval = null;
    }

    function parseICalDate(value) {
      if (!value) return null;
      const clean = value.trim();
      if (/^\d{8}T\d{6}Z$/.test(clean)) {
        return new Date(Date.UTC(clean.slice(0,4), Number(clean.slice(4,6)) - 1, clean.slice(6,8), clean.slice(9,11), clean.slice(11,13), clean.slice(13,15)));
      }
      if (/^\d{8}T\d{6}$/.test(clean)) {
        return new Date(clean.slice(0,4), Number(clean.slice(4,6)) - 1, clean.slice(6,8), clean.slice(9,11), clean.slice(11,13), clean.slice(13,15));
      }
      if (/^\d{8}$/.test(clean)) {
        return new Date(clean.slice(0,4), Number(clean.slice(4,6)) - 1, clean.slice(6,8), 8, 0, 0);
      }
      const tentative = new Date(clean);
      return Number.isNaN(tentative.getTime()) ? null : tentative;
    }

    function normalizeICal(text) {
      return text.replace(/\r\n[ \t]/g, '').replace(/\n[ \t]/g, '').replace(/\r\n/g, '\n');
    }

    function parseICalText(text) {
      const normalized = normalizeICal(text);
      const eventBlocks = normalized.match(/BEGIN:VEVENT[\s\S]*?END:VEVENT/g) || [];
      return eventBlocks.map(block => {
        const summary = (block.match(/^SUMMARY(?:;[^:]*)?:(.*)$/m) || [,'Cours'])[1].trim();
        const location = (block.match(/^LOCATION(?:;[^:]*)?:(.*)$/m) || [,'Salle non renseignée'])[1].trim();
        const dtstart = (block.match(/^DTSTART(?:;[^:]*)?:(.*)$/m) || [,''])[1].trim();
        const dtend = (block.match(/^DTEND(?:;[^:]*)?:(.*)$/m) || [,''])[1].trim();
        const start = parseICalDate(dtstart);
        const end = parseICalDate(dtend);
        if (!start) return null;
        const day = weekDays[(start.getDay() + 6) % 7];
        const startTime = formatShortTime(start);
        const endTime = end ? formatShortTime(end) : '';
        return {
          id: uid(),
          subject: summary || 'Cours',
          location: location || 'Salle non renseignée',
          start: start.toISOString(),
          end: end ? end.toISOString() : null,
          displayTime: endTime ? `${startTime} → ${endTime}` : startTime,
          meta: `${day} • ${location || 'Salle non renseignée'}`
        };
      }).filter(Boolean).sort((a,b) => new Date(a.start) - new Date(b.start));
    }

    async function importICSFile(event) {
      const file = event.target.files?.[0];
      if (!file) return;
      const text = await file.text();
      state.pronoteEvents = parseICalText(text);
      state.pronoteSource = `Fichier : ${file.name}`;
      saveState();
      renderAll();
    }

    async function importICSUrl() {
      const input = document.getElementById('pronoteIcalInput');
      const url = input.value.trim();
      if (!url) return;
      state.pronoteUrl = url;
      try {
        const response = await fetch(url);
        if (!response.ok) throw new Error();
        const text = await response.text();
        state.pronoteEvents = parseICalText(text);
        state.pronoteSource = `URL : ${url}`;
        saveState();
        renderAll();
      } catch {
        alert('Le navigateur ou le serveur bloque cette URL. Utilise un fichier .ics local.');
        saveState();
      }
    }

    function loadPronoteDemo() {
      const demo = `BEGIN:VCALENDAR\nVERSION:2.0\nBEGIN:VEVENT\nSUMMARY:Mathématiques\nLOCATION:Salle B204\nDTSTART:20260316T080000\nDTEND:20260316T093000\nEND:VEVENT\nBEGIN:VEVENT\nSUMMARY:Physique\nLOCATION:Labo 2\nDTSTART:20260316T100000\nDTEND:20260316T113000\nEND:VEVENT\nBEGIN:VEVENT\nSUMMARY:Anglais\nLOCATION:Salle A110\nDTSTART:20260317T090000\nDTEND:20260317T103000\nEND:VEVENT\nBEGIN:VEVENT\nSUMMARY:Informatique\nLOCATION:C307\nDTSTART:20260318T133000\nDTEND:20260318T150000\nEND:VEVENT\nBEGIN:VEVENT\nSUMMARY:Histoire\nLOCATION:A101\nDTSTART:20260319T110000\nDTEND:20260319T123000\nEND:VEVENT\nEND:VCALENDAR`;
      state.pronoteEvents = parseICalText(demo);
      state.pronoteSource = 'Démo intégrée';
      saveState();
      renderAll();
    }

    elements.searchInput.addEventListener('input', e => {
      state.search = e.target.value;
      saveState();
      renderAll();
    });

    elements.themeShortcut.addEventListener('click', () => {
      state.dark = !state.dark;
      saveState();
      renderAll();
    });

    elements.menuBtn.addEventListener('click', () => {
      elements.mobileDrawer.classList.toggle('show');
    });

    elements.assistantButton.addEventListener('click', () => {
      state.activeTab = 'stats';
      saveState();
      renderAll();
    });

    elements.closeModalBtn.addEventListener('click', closeModal);
    elements.modal.addEventListener('click', e => { if (e.target === elements.modal) closeModal(); });

    if (state.focusRunning) startFocusTimer();
    applyTheme();
    renderAll();
  </script>
</body>
</html>