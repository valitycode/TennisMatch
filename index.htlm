              <div class="section-header"><div><h2>Mes tâches</h2><p class="section-subtle">Clique sur une tâche pour la cocher.</p></div><button class="primary-btn" id="addTaskBtn" style="width:auto;background:#0f172a;color:white;">+ Ajouter une tâche</button></div>
              <div class="task-list">${filteredTasks().map(taskCard).join('') || `<article class="note-card"><h3>Aucune tâche</h3></article>`}</div>
            </div>
          </section>
